#!/usr/bin/env sh
# Pre-push gate for mnemos. Runs lint + typecheck across all workspace
# packages. This catches everything `next build` would catch on the
# server side, plus TypeScript errors that don't surface in lint alone.
#
# This is the contract that makes "production builds never fail":
# whatever Vercel runs server-side, you've already passed locally.
#
# If this fails: fix the issues, re-stage, commit, push. The hook is
# strict because the OSS quality bar is strict. Use `pnpm validate` to
# also run the test suite manually before pushing.
echo "[mnemos pre-push] Running pnpm lint + pnpm typecheck…"
pnpm lint && pnpm typecheck

{
  "name": "mnemos-monorepo",
  "version": "0.17.1",
  "private": true,
  "description": "Personal RAG. Local-first. Drop a folder, ask a question.",
  "homepage": "https://github.com/cosmicflow-space/mnemos",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cosmicflow-space/mnemos.git"
  },
  "bugs": {
    "url": "https://github.com/cosmicflow-space/mnemos/issues"
  },
  "license": "MIT",
  "author": "Zen Algorithms LLC",
  "type": "module",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "setup": "node setup.mjs",
    "dev": "pnpm --filter @mnemos/web dev",
    "build": "pnpm -r --filter=!@mnemos/web build && pnpm --filter @mnemos/web build",
    "start": "pnpm --filter @mnemos/web start",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint .",
    "validate": "pnpm lint && pnpm typecheck && pnpm test",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "husky": "^9.1.7",
    "oxlint": "^0.13.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "minimumReleaseAge": 2880
  }
}

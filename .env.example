# Mnemos .env example
#
# Quick start:
# 1) Copy this file to `.env` (for local clone-and-run) OR to `~/.mnemos/.env`
# 2) Fill only the values you use
# 3) Never commit real secrets to git
#
# Env precedence (highest -> lowest):
#   process env -> ./.env -> ~/.mnemos/.env -> ~/.mnemos/config.json
#
# -----------------------------------------------------------------------------
# Networking
# -----------------------------------------------------------------------------

# Bind address. Default 127.0.0.1 (loopback only).
# Set to "lan" or "0.0.0.0" to expose on LAN (NOT recommended without auth).
# MNEMOS_BIND=127.0.0.1

# Port. Default 3030.
# MNEMOS_PORT=3030

# Auth token. Auto-generated on first start if blank. Refuses to start if set to the
# documented example placeholder, so never copy-paste an example value verbatim.
# MNEMOS_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# State paths (defaults shown)
# -----------------------------------------------------------------------------

# MNEMOS_STATE_DIR=~/.mnemos
# MNEMOS_DB_PATH=~/.mnemos/mnemos.db
# (audit data lives in the audit_event table inside mnemos.db — no separate file)

# -----------------------------------------------------------------------------
# Optional: import API keys from your login shell profile (~/.profile / .zshrc)
# -----------------------------------------------------------------------------

# MNEMOS_LOAD_SHELL_ENV=1
# MNEMOS_SHELL_ENV_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Embedding provider (default = embed-local, bundled, free, no external services)
# -----------------------------------------------------------------------------

# Override the cache directory for the bundled local embedding model
# (Hugging Face ONNX weights, ~130MB for BGE-small-en-v1.5, downloaded on
# first use). Defaults to ~/.cache/huggingface/transformers.
# MNEMOS_TRANSFORMERS_CACHE=~/.mnemos/transformers-cache

# -----------------------------------------------------------------------------
# Chat LLM provider API keys (set at least one if you want frontier models;
# all Mnemos LLM features also work with fully-local Ollama or llama.cpp)
# -----------------------------------------------------------------------------

# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...
# GOOGLE_API_KEY=...

# Local LLM via Ollama (optional)
# OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Defaults
# -----------------------------------------------------------------------------

# Tier 1 (fully local) is the default. Uncomment + change ONLY if you want
# the server to default to a different provider for callers that omit providerId.
# MNEMOS_DEFAULT_PROVIDER=ollama
# MNEMOS_DEFAULT_EMBEDDING=embed-local
# MNEMOS_CHUNK_SIZE=1000
# MNEMOS_CHUNK_OVERLAP=200
# MNEMOS_TOP_K=8
# MNEMOS_MEMORY_TURNS=10

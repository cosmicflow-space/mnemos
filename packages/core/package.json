{
  "name": "@mnemos/core",
  "version": "0.1.0",
  "description": "Core RAG pipeline + plugin registry for Mnemos.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@mnemos/db": "workspace:*",
    "@mnemos/plugin-sdk": "workspace:*",
    "@mnemos/plugin-embed-local": "workspace:*",
    "@mnemos/plugin-anthropic": "workspace:*",
    "@mnemos/plugin-openai": "workspace:*",
    "@mnemos/plugin-gemini": "workspace:*",
    "@mnemos/plugin-ollama": "workspace:*",
    "@mnemos/plugin-llama-cpp": "workspace:*",
    "@mnemos/plugin-loader-pdf": "workspace:*",
    "@mnemos/plugin-loader-markdown": "workspace:*",
    "@mnemos/plugin-loader-plaintext": "workspace:*",
    "@mnemos/plugin-loader-web": "workspace:*",
    "@mnemos/plugin-loader-code": "workspace:*",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0"
  }
}

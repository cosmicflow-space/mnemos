{
  "name": "@mnemos/plugin-sdk",
  "version": "0.1.0",
  "description": "Plugin SDK barrel for Mnemos. The only surface plugins are allowed to import from.",
  "license": "MIT",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}

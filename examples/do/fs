#!/bin/sh
# /do fs <name…> — fuzzy file-name hunt under $HOME.
#
# Accepts a NATURAL query: spaces ("Land Rover"), camelCase ("LandRover"),
# separators ("land_rover"), or leftover glob chars ("Land*Rover*.pdf") all work.
# The query is tokenized (split on camelCase / spaces / . _ - * ? [ ]) and a file
# matches when its NAME contains EVERY token, case-insensitive and order-free.
# READ-only: it observes file names, never contents.
#
# $1 is pre-validated by the dispatcher (letters/digits/spaces and . _ - * ? [ ]
# only — no '/', '..', or quotes), so it is data, never a path or shell syntax.
set -u

query="${1:?usage: fs <name>}"
limit=50
case "$query" in *"'"* | *'"'*) echo "fs: illegal character" >&2; exit 2 ;; esac

# Tokenize: split camelCase, turn separators/glob chars into spaces, lowercase.
tokens=$(printf '%s' "$query" \
  | sed -E 's/([a-z0-9])([A-Z])/\1 \2/g' \
  | tr -c 'a-zA-Z0-9' ' ' \
  | tr 'A-Z' 'a-z' \
  | tr -s ' ' \
  | sed -E 's/^ +//; s/ +$//')
[ -n "$tokens" ] || exit 0

# Seed the candidate search with the LONGEST token (most selective).
seed=$(printf '%s\n' $tokens | awk '{ if (length($0) > length(m)) m = $0 } END { print m }')

filter() {
  grep -v -e '/node_modules/' -e '/Library/' -e '/\.git/' -e '/\.Trash/' \
    -e '/\.cache/' -e '/\.npm/' -e '/\.ssh/' -e '/\.gnupg/' -e '/\.aws/'
}

# Candidate set: file names containing the seed token. Spotlight fast-path.
candidates() {
  if command -v mdfind >/dev/null 2>&1 && mdutil -s / 2>/dev/null | grep -q "Indexing enabled"; then
    mdfind -onlyin "$HOME" "kMDItemFSName == '*$seed*'wc" 2>/dev/null
  else
    find "$HOME" \( -name node_modules -o -name .git -o -name Library -o -name .ssh \
      -o -name .aws -o -name .gnupg -o -name .Trash -o -name .cache -o -name .npm \) -prune \
      -o -type f -iname "*$seed*" -print 2>/dev/null
  fi
}

# Keep regular files whose lowercased basename contains EVERY token; cap output.
count=0
candidates | filter | while IFS= read -r path; do
  [ -f "$path" ] || continue
  base=$(printf '%s' "${path##*/}" | tr 'A-Z' 'a-z')
  ok=1
  for t in $tokens; do
    case "$base" in *"$t"*) ;; *) ok=0; break ;; esac
  done
  [ "$ok" = 1 ] || continue
  count=$((count + 1))
  if [ "$count" -gt "$limit" ]; then
    echo "...more than $limit matches; add another word to narrow." >&2
    break
  fi
  printf '%s\n' "$path"
done

exit 0
